{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user data.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "tier": { "type": "string", "enum": ["standard"] },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["email", "tier", "expiryDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    }
  }
}
