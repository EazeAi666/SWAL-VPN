rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (Phase 3: Primitives)
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      ) || request.auth.token.email == "isrealadesina3@gmail.com";
    }

    // Validation Blueprint for UserProfile
    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'tier', 'expiryDate']) &&
             data.keys().size() <= 5 && // email, tier, expiryDate, isAdmin, uid
             data.email is string && data.email.size() <= 256 &&
             data.tier in ['standard', 'premium'] &&
             data.expiryDate is timestamp &&
             (data.get('isAdmin', false) is bool) &&
             (data.get('uid', '') is string);
    }

    // ===============================================================
    // Collection: users
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list users

      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUserProfile(incoming()) &&
                      incoming().isAdmin == false; // Users cannot make themselves admin
      
      allow update: if (isOwner(userId) && isValidId(userId) && (
        // Action: Update settings (only non-sensitive fields)
        isValidUserProfile(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['email']) && // Only email can be updated by user
        incoming().isAdmin == existing().isAdmin &&
        incoming().tier == existing().tier &&
        incoming().expiryDate == existing().expiryDate
      )) || isAdmin();

      allow delete: if isAdmin();
    }
  }
}
